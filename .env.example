# Vercel will auto-inject these when you connect Postgres in the dashboard.
# Locally, copy this to .env.local and paste from Vercel → Storage → Postgres → .env.local tab

POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
